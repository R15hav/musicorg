# ─── musicorg generated state ───────────────────────────────────────────────
# Runtime state lives under XDG ~/.local/share/musicorg/<slug>/ — never in repo.
# Inside the source tree these are produced by running the pipeline against the
# test fixture, and should not be committed.
tests/fixtures/library-small/Music/
tests/fixtures/library-small/_duplicates/
tests/fixtures/library-small/_misc/
tests/fixtures/library-small/_replaced/
tests/fixtures/library-small/_upgrade_staging/
tests/fixtures/library-small/**/_duplicates/

# Local musicorg state if someone runs it from this directory
.musicorg-state/

# ─── Reference pipeline (entire folder is local-only) ───────────────────────
# Original 34-script pipeline + design docs + personal run state. Kept on disk
# for development reference but never tracked: it contains DRM material,
# cookies, and personal music-library state.
_organizer/

