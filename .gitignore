# ─── Secrets / credentials (NEVER commit) ───────────────────────────────────
# Apple Music DRM material — Widevine device files, cookies, Android wrapper state
*.wvd
*.sids
*.pb
*.pdat
cookies.txt
cookies.txt.bak
*.cookies
.env
